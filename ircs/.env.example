# ── IRCS environment variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── LLM provider (set ONE, priority: Groq > Anthropic > Pollinations) ────────

# OPTION 1 – Groq (RECOMMENDED – fastest, truly free, no credit card)
# Sign up at https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=

# OPTION 2 – Anthropic Claude ($5 free credit on new account)
# Sign up at https://console.anthropic.com → API Keys → Create Key
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTION 3 – Pollinations.ai (zero signup, leave both keys blank above)
# Works automatically if GROQ_API_KEY and ANTHROPIC_API_KEY are not set.

# SQLite database path (relative to ircs/ directory)
DB_PATH=
